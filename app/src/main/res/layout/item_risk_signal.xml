<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/containerBg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_margin="8dp"
    android:background="@drawable/bg_rounded_corner">

    <!-- Header with severity badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvSeverity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HIGH"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_rounded_corner" />

        <TextView
            android:id="@+id/tvResolved"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ Resolved"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 hours ago"
            android:textSize="11sp"
            android:textColor="#999999" />

    </LinearLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Provider X: High Cancellation Rate"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="4dp" />

    <!-- Description -->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cancellation rate has exceeded safe threshold"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginBottom="8dp" />

    <!-- Entity and Metric -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Entity: "
            android:textSize="11sp"
            android:textColor="#999999"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/tvEntity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="John Doe"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginEnd="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Metric: "
            android:textSize="11sp"
            android:textColor="#999999"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/tvMetric"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="40% ↑"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#D32F2F" />

    </LinearLayout>

</LinearLayout>
